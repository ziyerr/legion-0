#!/usr/bin/env bash
# Short command shim for Legion.
#
#   legion 0                -> initialize current project Legion files
#   legion h                -> start/resume Claude L1 + Codex L1
#   cc l1 <name>            -> Legion Claude L1 shortcut
#   cx l1 <name>            -> Legion Codex L1 shortcut
#   legion codex l1 <name>  -> legion.sh codex l1 <name>
#   legion ...              -> legion.sh ...

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
LEGION_SH="${LEGION_SH:-$SCRIPT_DIR/legion.sh}"

exec "$LEGION_SH" "$@"
