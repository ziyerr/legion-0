{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Legion Canonical Memory",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "memory_id",
    "memory_type",
    "scope",
    "source_app",
    "source_type",
    "source_id",
    "source_file",
    "project_hash",
    "project_path",
    "legion_id",
    "commander_id",
    "parent_commander_id",
    "campaign_id",
    "task_id",
    "rollup_level",
    "title",
    "summary",
    "content",
    "evidence",
    "tags",
    "confidence",
    "permissions",
    "invalidated_by",
    "created_at",
    "updated_at",
    "content_hash",
    "reference_count",
    "last_referenced_at",
    "reward_signal"
  ],
  "properties": {
    "schema_version": {"enum": [1, 2]},
    "memory_id": {"type": "string", "minLength": 4},
    "memory_type": {
      "type": "string",
      "enum": ["thought", "summary", "preference", "user_profile", "project", "fact", "technical", "environment", "workflow", "tactic", "skill", "identity", "episode"]
    },
    "scope": {"type": "string", "enum": ["system", "global", "project", "legion", "commander", "app", "private"]},
    "source_app": {"type": "string", "minLength": 1},
    "source_type": {"type": "string", "minLength": 1},
    "source_id": {"type": "string"},
    "source_file": {"type": "string"},
    "project_hash": {"type": "string"},
    "project_path": {"type": "string"},
    "legion_id": {"type": "string"},
    "commander_id": {"type": "string"},
    "parent_commander_id": {"type": "string"},
    "campaign_id": {"type": "string"},
    "task_id": {"type": "string"},
    "rollup_level": {"type": "string"},
    "title": {"type": "string"},
    "summary": {"type": "string"},
    "content": {"type": "string"},
    "evidence": {"type": "array", "items": {"type": "string"}},
    "tags": {"type": "array", "items": {"type": "string"}},
    "confidence": {"type": "number", "minimum": 0, "maximum": 1},
    "permissions": {"type": "object"},
    "invalidated_by": {"type": "array", "items": {"type": "string"}},
    "created_at": {"type": "string"},
    "updated_at": {"type": "string"},
    "content_hash": {"type": "string", "minLength": 12},
    "embedding": {"type": ["array", "null"], "items": {"type": "number"}},
    "reference_count": {"type": "integer", "minimum": 0},
    "last_referenced_at": {"type": "string"},
    "reward_signal": {"type": "number"}
  }
}
