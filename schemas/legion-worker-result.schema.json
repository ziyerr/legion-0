{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Legion worker result",
  "type": "object",
  "additionalProperties": false,
  "required": ["status", "summary", "files_touched", "verification", "findings", "risks"],
  "properties": {
    "status": {
      "type": "string",
      "enum": ["completed", "blocked", "failed"]
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "files_touched": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "verification": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["command", "result", "details"],
        "properties": {
          "command": {
            "type": "string"
          },
          "result": {
            "type": "string",
            "enum": ["pass", "fail", "not-run"]
          },
          "details": {
            "type": ["string", "null"]
          }
        }
      }
    },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["severity", "file", "line", "description", "recommendation"],
        "properties": {
          "severity": {
            "type": "string",
            "enum": ["critical", "major", "minor", "suggestion"]
          },
          "file": {
            "type": ["string", "null"]
          },
          "line": {
            "type": ["integer", "null"],
            "minimum": 1
          },
          "description": {
            "type": "string"
          },
          "recommendation": {
            "type": ["string", "null"]
          }
        }
      }
    },
    "risks": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
